# Copy to .env and fill in. NEVER commit a real key.
GROQ_API_KEY=your_groq_api_key_here
# Default model. 8B is chosen for its far larger free-tier DAILY token budget (~500k vs ~100k for
# 70B), which keeps a graded deployment from exhausting tokens. Swap to llama-3.3-70b-versatile
# for higher selection quality if you have the budget.
GROQ_MODEL=llama-3.1-8b-instant
GROQ_STATE_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT=10
CHAT_BUDGET_SECONDS=26
