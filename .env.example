# Copy to .env and fill in. NEVER commit a real key.
GROQ_API_KEY=your_groq_api_key_here
# Default model. 8B is chosen for its far larger free-tier DAILY token budget (~500k vs ~100k for
# 70B), which keeps a graded deployment from exhausting tokens. Swap to llama-3.3-70b-versatile
# for higher selection quality if you have the budget.
GROQ_MODEL=llama-3.1-8b-instant
GROQ_STATE_MODEL=llama-3.1-8b-instant
# Optional: point the heavier selection call at a different model than GROQ_MODEL. Useful because
# each Groq model has its own tokens-per-minute bucket, so splitting state/select across models
# avoids them competing for one bucket under load. Defaults to GROQ_MODEL when unset.
# GROQ_SELECT_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT=10
CHAT_BUDGET_SECONDS=26
